{
  "permissions": {
    "allow": [
      "Read(~/.zshrc)",
      "Bash(./godot *)",
      "Bash(source *)",
      "Bash(gdlint *)",
      "Bash(gdformat *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(bash *)",
      "Bash(uv *)",
      "Bash(jq *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; echo \"$f\" | grep -qE '\\.gd$' && echo \"$f\" | grep -qv '/addons/' && gdlint \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Running gdlint..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check.sh",
            "statusMessage": "gdlint + gdformat + GUT...",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
